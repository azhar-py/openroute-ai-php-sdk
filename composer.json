{
    "name": "azhar-py/openroute-ai-php-sdk",
    "description": "A simple, clean, reusable PHP SDK for the OpenRouter AI API.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Azhar Khan"
        }
    ],
    "require": {
        "php": ">=7.4",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5"
    },
    "autoload": {
        "psr-4": {
            "OpenRouteAI\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OpenRouteAI\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/openroute"
    ]
}
